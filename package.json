{
  "name": "csp-report-worker",
  "version": "1.0.0",
  "description": "Cloudflare Worker that accepts CSP violation reports, stores them in KV, and forwards notifications via webhooks and email.",
  "license": "GPL-3.0-or-later",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:dashboard": "vite",
    "build:dashboard": "vite build",
    "deploy": "npm run build:dashboard && wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "types": "wrangler types",
    "typecheck": "tsc --noEmit && svelte-check --tsconfig dashboard/tsconfig.json"
  },
  "dependencies": {
    "@tanstack/svelte-query": "^6.0.0",
    "aws4fetch": "^1.0.20",
    "bits-ui": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "hono": "^4.12.18",
    "lucide-svelte": "^1.0.0",
    "mimetext": "^3.0.28",
    "svelte": "^5.46.0",
    "svelte-sonner": "^1.0.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.0",
    "@cloudflare/workers-types": "^4.20260502.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.4",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.0",
    "wrangler": "^4.90.0"
  }
}
