{
  "name": "csp-report-worker",
  "version": "1.0.0",
  "description": "Cloudflare Worker that accepts CSP violation reports, stores them in KV, and forwards notifications via webhooks and email.",
  "license": "GPL-3.0-or-later",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:dashboard": "vite",
    "build:dashboard": "vite build",
    "deploy": "npm run build:dashboard && wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "types": "wrangler types",
    "typecheck": "tsc --noEmit && tsc --noEmit -p dashboard/tsconfig.json"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tanstack/react-query": "^5.100.7",
    "aws4fetch": "^1.0.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "hono": "^4.12.16",
    "lucide-react": "^1.14.0",
    "mimetext": "^3.0.28",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "^7.14.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.0",
    "@cloudflare/workers-types": "^4.20250410.0",
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.10",
    "vitest": "^3.1.0",
    "wrangler": "^4.0.0"
  }
}
